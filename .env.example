DATABASE_URL="file:./prisma/dev.db"

# Docker: the `dev` service sets DATABASE_URL=file:/app/data/app.db (see docker-compose.yml).
# Seed and migrate inside the container so users exist in that database, e.g.:
#   docker compose exec dev npx prisma db push
#   docker compose exec dev npm run db:seed
# Seeding only on the host with the line above writes to prisma/dev.db — the container app will not see those users.

# Session cookies (iron-session). In production, set to a random string of at least 32 characters.
# SESSION_SECRET=

# Seed data (`npm run db:seed` after `db:push`; uses `prisma/seed.ts` + OpenAI when OPENAI_API_KEY is set).
# Dev-only defaults; change in production.
# SEED_ADMIN_EMAIL=admin@intake.local
# SEED_ADMIN_PASSWORD=ChangeMeAdmin!23
# SEED_ADMIN_NAME=Default Admin
# SEED_DEMO_USER_PASSWORD=DemoUserPass!23
#
# Demo users created by seed (same password for all unless SEED_DEMO_USER_PASSWORD is set):
#   alex.morgan@demo.intake, sam.okonkwo@demo.intake, riley.park@demo.intake — 3 intakes each.

# Required for AI helper + automatic intake enrichment on create (never commit real keys)
OPENAI_API_KEY=

# Optional: default is gpt-4o-mini (fast / inexpensive)
# OPENAI_MODEL=gpt-4o-mini
#
# If the primary model fails after retries, the app tries this model once (same default unless unset).
# Set to the same value as OPENAI_MODEL to disable fallback.
# OPENAI_FALLBACK_MODEL=gpt-4o-mini
