{
  "name": "project-intake-triage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:gate": "prisma validate && vitest run",
    "predev": "npm run test:gate",
    "prestart": "npm run test:gate",
    "dev": "next dev",
    "docker:dev": "docker compose up dev",
    "onboard": "bash scripts/onboard.sh",
    "docker:prod": "docker compose --profile prod up --build web",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "clean": "rm -rf .next"
  },
  "prisma": {
    "seed": "node ./node_modules/tsx/dist/cli.mjs prisma/seed.ts"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.8",
    "@mui/material": "^6.4.8",
    "@mui/material-nextjs": "^6.4.8",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "iron-session": "^8.0.4",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
